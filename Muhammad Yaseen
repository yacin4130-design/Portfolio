<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:#0a0a0a;color:#f5f5f5;overflow-x:hidden}

/* Scrollbar */
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:#0a0a0a}
::-webkit-scrollbar-thumb{background:#333;border-radius:3px}

/* ===== HERO ===== */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;position:relative;overflow:hidden;background:radial-gradient(ellipse at 30% 20%,rgba(255,255,255,0.04) 0%,transparent 50%),radial-gradient(ellipse at 70% 80%,rgba(255,255,255,0.02) 0%,transparent 50%)}
.hero::after{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.015'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");pointer-events:none;opacity:0.5}
.hero-content{text-align:center;z-index:2;position:relative;padding:0 2rem}
.hero-label{font-family:'Inter',sans-serif;font-size:0.65rem;letter-spacing:0.5em;text-transform:uppercase;color:#444;margin-bottom:2rem;opacity:0;animation:fadeUp 1s ease forwards}
.hero-name{font-family:'Playfair Display',serif;font-size:clamp(3.5rem,10vw,8rem);font-weight:900;color:#fff;letter-spacing:-0.04em;line-height:0.95;margin-bottom:1.5rem;opacity:0;animation:fadeUp 1s ease 0.2s forwards}
.hero-title{font-family:'Inter',sans-serif;font-size:clamp(0.85rem,2vw,1.1rem);font-weight:300;letter-spacing:0.35em;text-transform:uppercase;color:#666;margin-bottom:3rem;opacity:0;animation:fadeUp 1s ease 0.4s forwards}
.hero-divider{width:60px;height:1px;background:linear-gradient(90deg,transparent,#333,transparent);margin:0 auto 3rem;opacity:0;animation:fadeIn 1s ease 0.6s forwards}
.hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:3rem;max-width:900px;margin:0 auto;opacity:0;animation:fadeUp 1s ease 0.8s forwards}
.stat{text-align:center;position:relative}
.stat::after{content:'';position:absolute;right:-1.5rem;top:50%;transform:translateY(-50%);width:1px;height:40px;background:#1a1a1a}
.stat:last-child::after{display:none}
.stat-number{font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3.5rem);font-weight:700;color:#fff;line-height:1;background:linear-gradient(135deg,#fff 0%,#888 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.stat-label{font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;color:#555;margin-top:0.75rem;font-weight:500}
.hero-contact{display:flex;gap:2.5rem;justify-content:center;margin-top:4rem;flex-wrap:wrap;opacity:0;animation:fadeUp 1s ease 1s forwards}
.hero-contact-item{display:flex;align-items:center;gap:0.5rem;font-size:0.75rem;color:#555}
.hero-contact-item svg{width:14px;height:14px;stroke:#444}
.scroll-indicator{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:0.75rem;opacity:0;animation:fadeIn 1s ease 1.4s forwards}
.scroll-text{font-size:0.6rem;letter-spacing:0.4em;text-transform:uppercase;color:#333}
.scroll-line{width:1px;height:35px;background:linear-gradient(to bottom,#333,transparent);animation:scrollPulse 2.5s ease infinite}

/* ===== SECTIONS ===== */
.section{padding:10rem 2rem;max-width:1400px;margin:0 auto;position:relative}
.section-alt{background:#070707}
.section-header{text-align:center;margin-bottom:8rem}
.section-label{font-family:'Inter',sans-serif;font-size:0.6rem;letter-spacing:0.5em;text-transform:uppercase;color:#444;margin-bottom:1.5rem;font-weight:500}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(2.2rem,5vw,4rem);font-weight:700;color:#fff;line-height:1.1;letter-spacing:-0.02em}
.section-sub{font-size:0.95rem;color:#555;margin-top:1.5rem;max-width:650px;margin-left:auto;margin-right:auto;line-height:1.8;font-weight:300}

/* ===== 3D CARDS ===== */
.card-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(400px,1fr));gap:2.5rem;perspective:2000px}
.card-3d{position:relative;transform-style:preserve-3d;transition:all 0.5s cubic-bezier(0.23,1,0.32,1)}
.card-3d:hover{transform:translateY(-12px)}
.card-inner{background:#0f0f0f;border:1px solid #1a1a1a;padding:3rem;position:relative;overflow:hidden;transition:all 0.4s ease;height:100%;display:flex;flex-direction:column}
.card-inner::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.08),transparent)}
.card-3d:hover .card-inner{border-color:#2a2a2a;box-shadow:0 30px 60px -15px rgba(0,0,0,0.9),0 0 0 1px rgba(255,255,255,0.03)}
.card-glow{position:absolute;inset:0;opacity:0;transition:opacity 0.4s ease;background:radial-gradient(600px circle at var(--mouse-x,50%) var(--mouse-y,50%),rgba(255,255,255,0.03),transparent 40%);pointer-events:none}
.card-3d:hover .card-glow{opacity:1}

/* Word Logo */
.word-logo{font-family:'Space Grotesk',sans-serif;font-size:1.8rem;font-weight:700;color:#fff;letter-spacing:-0.02em;margin-bottom:0.5rem;line-height:1.2}
.word-logo-alt{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:600;color:#fff;font-style:italic}
.word-logo-mono{font-family:'Space Grotesk',monospace;font-size:1.4rem;font-weight:500;color:#fff;letter-spacing:0.1em}
.word-logo-bold{font-family:'Inter',sans-serif;font-size:1.5rem;font-weight:800;color:#fff;letter-spacing:-0.03em;text-transform:uppercase}

.card-category{font-size:0.6rem;letter-spacing:0.35em;text-transform:uppercase;color:#444;margin-bottom:1.5rem;font-weight:500}
.card-name{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:600;color:#fff;margin-bottom:0.5rem;line-height:1.2}
.card-role{font-size:0.8rem;color:#666;margin-bottom:2rem;font-weight:400;line-height:1.5}
.card-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-bottom:2rem;padding-top:2rem;border-top:1px solid #1a1a1a;margin-top:auto}
.metric-value{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:600;color:#fff;line-height:1}
.metric-label{font-size:0.55rem;letter-spacing:0.15em;text-transform:uppercase;color:#444;margin-top:0.4rem;font-weight:500}
.card-desc{font-size:0.8rem;color:#555;line-height:1.8;margin-top:auto}
.card-link{position:absolute;top:1.5rem;right:1.5rem;width:32px;height:32px;border:1px solid #222;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:all 0.3s ease;opacity:0;transform:translateY(-5px)}
.card-3d:hover .card-link{opacity:1;transform:translateY(0)}
.card-link:hover{border-color:#444;background:rgba(255,255,255,0.03)}
.card-link svg{width:12px;height:12px;stroke:#666}

/* ===== FREELANCE ===== */
.freelance-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:1.5rem}
.freelance-card{background:#0c0c0c;border:1px solid #151515;padding:2.5rem;transition:all 0.4s ease;position:relative;overflow:hidden}
.freelance-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#2a2a2a,transparent);transform:scaleX(0);transition:transform 0.5s ease}
.freelance-card:hover::after{transform:scaleX(1)}
.freelance-card:hover{border-color:#222;transform:translateY(-6px);box-shadow:0 20px 40px -10px rgba(0,0,0,0.8)}
.freelance-logo{font-family:'Space Grotesk',sans-serif;font-size:1.4rem;font-weight:700;color:#fff;margin-bottom:0.75rem;letter-spacing:-0.01em}
.freelance-logo-alt{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:600;color:#fff;font-style:italic}
.freelance-name{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:600;color:#fff;margin-bottom:0.3rem}
.freelance-role{font-size:0.7rem;color:#444;margin-bottom:1.5rem;letter-spacing:0.05em}
.freelance-metrics{display:flex;gap:2rem;margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid #151515}
.freelance-metric{font-size:0.7rem}
.freelance-metric span{display:block;font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:600;color:#fff;margin-bottom:0.2rem}
.freelance-metric label{font-size:0.5rem;letter-spacing:0.2em;text-transform:uppercase;color:#444;font-weight:500}
.freelance-desc{font-size:0.75rem;color:#555;line-height:1.7}
.freelance-link{position:absolute;top:1.5rem;right:1.5rem;font-size:0.6rem;color:#333;transition:color 0.3s ease;text-decoration:none;letter-spacing:0.1em}
.freelance-card:hover .freelance-link{color:#666}

/* ===== INFLUENCERS ===== */
.influencer-section{background:#050505;padding:8rem 2rem}
.influencer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;max-width:1200px;margin:0 auto}
.influencer-card{background:#0c0c0c;border:1px solid #151515;padding:2rem 1rem;text-align:center;transition:all 0.4s ease;position:relative}
.influencer-card:hover{border-color:#2a2a2a;transform:translateY(-5px);box-shadow:0 15px 30px -10px rgba(0,0,0,0.6)}
.influencer-initial{width:48px;height:48px;border-radius:50%;background:#111;border:1px solid #222;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#fff;transition:all 0.3s ease}
.influencer-card:hover .influencer-initial{background:#1a1a1a;border-color:#333}
.influencer-name{font-size:0.8rem;font-weight:500;color:#ddd;margin-bottom:0.4rem}
.influencer-region{font-size:0.55rem;letter-spacing:0.25em;text-transform:uppercase;color:#333;font-weight:500}
.influencer-count{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:#fff;text-align:center;margin-bottom:4rem}
.influencer-count-label{font-size:0.6rem;letter-spacing:0.4em;text-transform:uppercase;color:#444;margin-top:0.5rem}

/* ===== SKILLS ===== */
.skills-section{padding:8rem 2rem;max-width:1200px;margin:0 auto}
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem}
.skill-category{background:#0c0c0c;border:1px solid #151515;padding:2.5rem;transition:all 0.3s ease}
.skill-category:hover{border-color:#222}
.skill-category-title{font-family:'Playfair Display',serif;font-size:1rem;font-weight:600;color:#fff;margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid #1a1a1a}
.skill-list{list-style:none}
.skill-list li{font-size:0.75rem;color:#555;padding:0.5rem 0;border-bottom:1px solid #111;transition:all 0.3s ease;display:flex;align-items:center;gap:0.5rem}
.skill-list li::before{content:'';width:3px;height:3px;background:#333;border-radius:50%;transition:all 0.3s ease}
.skill-list li:hover{color:#ccc;padding-left:0.5rem}
.skill-list li:hover::before{background:#666}
.skill-list li:last-child{border-bottom:none}

/* ===== FOOTER ===== */
.footer{text-align:center;padding:5rem 2rem 3rem;border-top:1px solid #111;background:#050505}
.footer-name{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:#fff;margin-bottom:0.5rem;letter-spacing:-0.02em}
.footer-title{font-size:0.7rem;letter-spacing:0.4em;text-transform:uppercase;color:#444;margin-bottom:3rem;font-weight:500}
.footer-contact{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;max-width:800px;margin:0 auto;font-size:0.8rem;color:#555}
.footer-contact-item{display:flex;align-items:center;justify-content:center;gap:0.5rem;padding:1rem;background:#0c0c0c;border:1px solid #151515;transition:all 0.3s ease}
.footer-contact-item:hover{border-color:#222}
.footer-contact-item svg{width:14px;height:14px;stroke:#444}
.footer-contact-item a{color:#777;text-decoration:none;transition:color 0.3s ease}
.footer-contact-item a:hover{color:#fff}
.footer-bottom{margin-top:3rem;font-size:0.65rem;color:#222;letter-spacing:0.2em}

/* ===== ANIMATIONS ===== */
@keyframes fadeUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes scrollPulse{0%{transform:scaleY(1);opacity:1}50%{transform:scaleY(0.4);opacity:0.3}100%{transform:scaleY(1);opacity:1}}

/* Responsive */
@media(max-width:768px){
.hero-stats{grid-template-columns:repeat(2,1fr);gap:2rem}
.stat::after{display:none}
.card-grid{grid-template-columns:1fr}
.section{padding:5rem 1.5rem}
.hero-contact{gap:1rem}
}
</style>
</head>
